# DeepSeek API Key
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_api_key_here

# Optional: Override internal system prompt
#DEEPSEEK_AGENT_SYSTEM_PROMPT=""



# Optional: Model to use (default: deepseek-chat)
# DEEPSEEK_AGENT_MODEL=deepseek-chat

# Optional: Maximum conversation history length
# DEEPSEEK_AGENT_MAX_HISTORY_MESSAGES=20

# Optional: Maximum context tokens
# Default depends on model:
# - deepseek-chat: ~112000 (128K input - reserved for output & system)
# - deepseek-reasoner: ~104000 (128K input - reserved for output & system)
# - other models: 28000 (32K input - safety margin)
# DEEPSEEK_AGENT_MAX_CONTEXT_TOKENS=28000

# Optional: Retry configuration for API calls
# DEEPSEEK_AGENT_MAX_RETRIES=3
# DEEPSEEK_AGENT_RETRY_DELAY_MS=1000
# DEEPSEEK_AGENT_MAX_RETRY_DELAY_MS=30000

# Optional: Shell command execution timeout (milliseconds)
# DEEPSEEK_AGENT_SHELL_TIMEOUT_MS=5000

# Optional: Enable/disable response streaming (default: true)
# DEEPSEEK_AGENT_STREAM=true

# Optional: Enable debug logging
# DEEPSEEK_AGENT_DEBUG=1

# Optional: Disable colors (set to 1 to disable colors, empty for auto-detection)
# DEEPSEEK_AGENT_NO_COLOR=
# Optional: Force enable colors (set to 1 to force colors, empty for auto-detection)
# DEEPSEEK_AGENT_COLOR=

# Optional: Skip automatic loading of context files (AGENTS.md, README.md, CONTINUE.md)
# DEEPSEEK_AGENT_SKIP_CONTEXT_FILES=1
